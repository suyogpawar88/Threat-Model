# Copy this file to .env and fill in only the connectors you plan to use.
# None are mandatory -- the threat-modeling skill works with whatever subset
# is configured and asks the user for a manual description for the rest.

# --- Jira ---
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@your-org.com
JIRA_API_TOKEN=

# --- Jenkins ---
JENKINS_BASE_URL=https://jenkins.your-org.com
JENKINS_USER=
JENKINS_API_TOKEN=

# --- ServiceNow ---
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_USER=
SERVICENOW_PASSWORD=

# --- Code repository (GitHub by default) ---
REPO_PROVIDER=github
REPO_TOKEN=
REPO_OWNER=
REPO_NAME=

# --- Model configuration for scripts/summarize.py (token minimization) ---
# Used only to compress large connector payloads before they enter the main
# session's context. The main threat-modeling reasoning runs on whatever
# model is driving your Claude Code / Cowork session, not this setting.
ANTHROPIC_API_KEY=
MODEL_NAME=claude-sonnet-5
